<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Home</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100">
 <%- include('../partials/nav') %>
    <header class="bg-white shadow-md p-4">
      <h1 class="text-2xl font-bold text-center text-gray-800">
        🏠 Register Your Home
      </h1>
    </header>

    <!-- Form Section -->
    <main class="flex justify-center items-center min-h-screen">
      
      
      <form action="/host/add-home" method="POST" enctype="multipart/form-data"
        class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md space-y-4"
      >

        <h2 class="text-xl font-semibold text-center text-gray-700 mb-4">
          Add Home Details
        </h2>

        <!-- House Name -->
        <input
          type="text"
          name="name"
          placeholder="House Name"
          class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          required
        />

        <!-- Price -->
        <input
          type="text"
          name="price"
          placeholder="Price"
          class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          required
        />

        <!-- Location -->
        <input
          type="text"
          name="location"
          placeholder="Location"
          class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          required
        />

        <!-- Rating -->
        <input
          type="text"
          name="rating"
          placeholder="Rating (1–5)"
          class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          required
        />

        <!-- Photo URL -->
        <input
          type="file"
          accept="image/jpeg,image/jpg,image/png"
          name="photo"
          placeholder="Image URL"
          enctype="multipart/form-data"
          class="w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-400"
          required
        />

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 transition duration-300"
        >
          ➕ Add Home
        </button>

      </form>

    </main>

  </body>
</html>