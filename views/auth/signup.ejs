<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-orange-400 min-h-screen flex items-center justify-center">

  <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
    
    <h2 class="text-3xl font-bold text-center text-red-500 mb-6">
      signup
    </h2>

    <form action="/auth/signuphand" method="POST" class="space-y-4">
      <% if (typeof errors !== "undefined" && errors && errors.length > 0) { %>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
    
    <strong class="font-bold">Error!</strong> 
    <span class="block sm:inline">
      <ul class="list-disc ml-5 mt-2">
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </span>

    <span class="absolute top-0 bottom-0 right-0 px-4 py-3">
      <i class="fas fa-times cursor-pointer"></i>
    </span>

  </div>
<% } %>
      <div>
        <label class="block text-gray-700 mb-1">firstname</label>
        <input type="text" name="firstname" required
  class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-orange-400"
  placeholder="Enter your firstname"
  value="<%= oldInput && oldInput.firstname ? oldInput.firstname : '' %>" />
        <label class="block text-gray-700 mb-1 mt-2">lastname</label>
        <input type="text" name="lastname" required
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-orange-400"
          placeholder="Enter your lastname"
          value="<%=  oldInput && oldInput.lastname ? oldInput.lastname : '' %>"/>
      </div>

      <div>
        <label class="block text-gray-700 mb-1">user Email</label>
        <input type="email" name="email" required
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-orange-400"
          placeholder="Enter your email"
           value="<%=  oldInput && oldInput.email ? oldInput.email : '' %>"
          />
      </div>

      <div>
        <label class="block text-gray-700 mb-1">Password</label>
        <input type="password" name="password" required
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-orange-400"
          placeholder="create password"/>
      </div>

      <div>
        <label class="block text-gray-700 mb-1">confirm Password</label>
        <input type="password" name="confirmPassword" required
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-orange-400"
          placeholder="confirm password"/>
      </div>

      <!-- NEW: User / Host Option -->
      <div>
        <label class="block text-gray-700 mb-2">Select Role</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2">
            <input type="radio" name="role" value="user" required  
            <%=  oldInput && oldInput.role === 'user' ? 'checked' : '' %>/>
            User
          </label>
          <label class="flex items-center gap-2">
           <input type="radio" name="role" value="host" <input type="radio" name="role" value="host" <%= oldInput && oldInput.role === 'host' ? 'checked' : '' %> /> 
            Host
          </label>
        </div>
      </div>

      <!-- NEW: Terms & Conditions -->
      <div class="flex items-center gap-2">
        <input type="checkbox" name="terms" required />
        <label class="text-gray-700 text-sm">
          I agree to the Terms & Conditions
        </label>
      </div>

      <button 
        type="submit"
        class="w-full bg-orange-500 text-black py-2 rounded-md hover:bg-orange-600"
      >
        signup
      </button>

    </form>

    <p class="text-center mt-4 text-gray-600">
       have an account? 
      <a href="/auth/login" class="text-red-500 font-medium hover:underline">
        login up
      </a>
    </p>

  </div>

</body>
</html>