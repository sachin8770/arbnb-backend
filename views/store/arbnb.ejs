<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>airbnb Home</title>
    <link rel="stylesheet" href="/output.css" />
  </head>

  <body class="bg-gradient-to-br from-gray-50 to-orange-50 min-h-screen">
    <%- include('../partials/nav') %>

    <div class="pt-40 pb-12">
      <div class="max-w-7xl mx-auto px-4">
        <header class="text-center mb-16">
          <h1 class="text-5xl font-bold bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent mb-3">
            Welcome to airbnb
          </h1>
          <p class="text-gray-600 text-lg">Discover amazing places to stay</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center">
          <% registeredHomes.forEach(home => { %>
          <div class="w-full max-w-sm bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border-4 border-orange-200">
            <div class="relative">
              <img 
               src="<%=home.photo%>"
                alt="home image"
                class="w-full h-48 object-cover"
              />
              <div class="absolute top-4 right-4 bg-orange-500 text-white px-4 py-2 rounded-full font-bold shadow-lg">
                ⭐ <%= home.rating %>
              </div>
            </div>

            <div class="p-6">
              <h3 class="text-2xl font-bold text-gray-800 mb-4"><%= home.name %></h3>

              <div class="space-y-3 mb-6">
                <div class="flex items-center text-gray-700">
                  <span class="font-semibold">Price: ₹<%= home.price %>/night</span>
                </div>
                <div class="flex items-center text-gray-700">
                  <span class="font-semibold">Location: <%= home.location %></span>
                </div>
                <div class="flex items-center text-gray-700">
                  <span class="font-semibold">Rating: <%= home.rating %></span>
                </div>
              </div>

              <form action="/host/bookings/<%= home.id %>" method="POST" class="w-full">
                <button
                  type="submit"
                  class="w-full bg-gradient-to-r from-blue-500 to-blue-600 text-white py-3 rounded-xl hover:from-blue-600 hover:to-blue-700 transition font-bold text-lg shadow-md hover:shadow-lg"
                >
                  book
                </button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>