<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= home.name %> - Home Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
  <%- include('../partials/nav') %>

  <header class="bg-white shadow-md p-4">
    <h1 class="text-3xl font-bold text-center text-gray-800">🏠 <%= home.name %></h1>
  </header>

  <main class="max-w-4xl mx-auto p-6">
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      
      <!-- Image Section -->
      <div class="w-full h-96 overflow-hidden">
        <img src="<%=home.photo%>" alt="<%= home.name %>" class="w-full h-full object-cover" />
      </div>

      <!-- Content Section -->
      <div class="p-8">
        
        <!-- Basic Info -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-blue-50 p-4 rounded-lg">
            <p class="text-gray-600 text-sm">Price</p>
            <p class="text-2xl font-bold text-blue-600">₹<%= home.price %></p>
          </div>
          <div class="bg-green-50 p-4 rounded-lg">
            <p class="text-gray-600 text-sm">Location</p>
            <p class="text-lg font-semibold text-green-600"><%= home.location %></p>
          </div>
          <div class="bg-yellow-50 p-4 rounded-lg">
            <p class="text-gray-600 text-sm">Rating</p>
            <p class="text-2xl font-bold text-yellow-600">⭐ <%= home.rating %>/5</p>
          </div>
          <div class="bg-purple-50 p-4 rounded-lg">
            <p class="text-gray-600 text-sm">Property ID</p>
            <p class="text-lg font-semibold text-purple-600"><%= home._id %></p>
          </div>
        </div>

        <!-- Description -->
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800 mb-4">About this property</h2>
          <p class="text-gray-600 leading-relaxed">
            This beautiful home is located in <%= home.location %> and offers an exceptional living experience. 
            With a rating of <%= home.rating %> stars, it's a highly sought-after property. Perfect for families and 
            travelers looking for comfort and convenience.
          </p>
        </div>

        <!-- Amenities -->
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-800 mb-4">Amenities</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div class="flex items-center space-x-2">
              <span class="text-2xl">🛏️</span>
              <span class="text-gray-700">Bedroom</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-2xl">🚿</span>
              <span class="text-gray-700">Bathroom</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-2xl">🍳</span>
              <span class="text-gray-700">Kitchen</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-2xl">📺</span>
              <span class="text-gray-700">TV & Entertainment</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-2xl">🌐</span>
              <span class="text-gray-700">WiFi Internet</span>
            </div>
            <div class="flex items-center space-x-2">
              <span class="text-2xl">🅿️</span>
              <span class="text-gray-700">Parking</span>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          
          <!-- Book Button -->
          <form action="/host/bookings/<%=home.id%>" method="POST">
            <button type="submit" class="w-full bg-blue-500 text-white py-3 rounded-lg hover:bg-blue-600 transition duration-300 font-semibold">
              📅 Book Now
            </button>
          </form>

          <!-- Favorites Button -->
          <form action="/host/favourites/<%=home.id%>" method="POST">
            <button type="submit" class="w-full bg-red-500 text-white py-3 rounded-lg hover:bg-red-600 transition duration-300 font-semibold">
              ❤️ Add to Favorites
            </button>
          </form>

          <!-- PDF Download Button -->
         <div class="mt-4">
  <a href="/rules/<%= home._id %>" class="inline-flex items-center text-blue-600 hover:text-blue-800">
    
    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>

    Download House Rules

  </a>
</div>

        </div>

      </div>
    </div>
  </main>

</body>
</html>